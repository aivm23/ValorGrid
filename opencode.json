{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "permission": {
    "bash": {
      "*": "allow",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "rm -rf*": "deny",
      "Remove-Item -Recurse -Force*": "deny",
      "del /s*": "deny"
    },
    "edit": "allow"
  },
  "compaction": {
    "auto": true,
    "tail_turns": 15
  },
  "agent": {
    "test-gate": {
      "description": "Guardian before commit: runs ALL tests and blocks commits if anything fails.",
      "mode": "primary"
    }
  },
  "mcp": {
    "sqlite": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sqlite", "--db-path", "data/valorgrid.sqlite"],
      "enabled": true
    }
  }
}
