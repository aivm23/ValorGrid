{
  "name": "valorgrid",
  "version": "3.5.7",
  "private": true,
  "productName": "ValorGrid",
  "description": "Private local portfolio dashboard",
  "main": "desktop/main.js",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "node server.js",
    "desktop:dev": "electron .",
    "desktop:pack": "electron-builder --dir",
    "desktop:dist:win": "electron-builder --win nsis --publish never",
    "desktop:dist:win:clean": "powershell -ExecutionPolicy Bypass -File scripts/build-desktop-win.ps1",
    "release:checksums": "node scripts/generate-release-checksums.js dist",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write \"AGENTS.md\" \"README.md\" \"CHANGELOG.md\" \"docs/**/*.md\" \".github/workflows/*.yml\" \".github/ISSUE_TEMPLATE/*.md\" \"package.json\" \"package-lock.json\"",
    "format:check": "prettier --check \"AGENTS.md\" \"README.md\" \"CHANGELOG.md\" \"docs/**/*.md\" \".github/workflows/*.yml\" \".github/ISSUE_TEMPLATE/*.md\" \"package.json\" \"package-lock.json\"",
    "check": "npm run lint && npm run format:check && npm test",
    "typecheck": "tsc --noEmit",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-db.ps1",
    "db:reset": "powershell -ExecutionPolicy Bypass -File scripts/reset-db.ps1",
    "db:doctor": "powershell -ExecutionPolicy Bypass -File scripts/db-doctor.ps1",
    "backup": "npm run db:backup",
    "seed:demo": "node scripts/seed-loadtest-db.js",
    "verify:publication": "powershell -ExecutionPolicy Bypass -File scripts/verify-publication.ps1"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.valorgrid.app",
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "src/**/*",
      "client/**/*",
      "assets/brand/valorgrid-logo.png",
      "vendor/**/*",
      "index.html",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "assets/brand/valorgrid-logo.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ValorGrid"
    }
  }
}
