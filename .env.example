# Optional local overrides. Copy to .env or set environment variables manually.
# Never commit .env files with personal paths or credentials.

HOST=127.0.0.1
PORT=1325

# Optional. If unset, the app uses an existing legacy ./portfolio.sqlite
# or creates ./data/portfolio.sqlite for a fresh install.
# PORTFOLIO_DB_PATH=C:\path\to\your\private\portfolio.sqlite

# Optional. If unset, backups use ./.backups in repo/local server mode.
# The Windows desktop app sets this automatically to its user data folder.
# VALORGRID_BACKUP_DIR=C:\path\to\your\private\backups
