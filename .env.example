# Optional local overrides. Copy to .env or set environment variables manually.
# Never commit .env files with personal paths or credentials.

HOST=127.0.0.1
PORT=1325

# Optional. If unset, the app uses local/valorgrid/data/portfolio.sqlite.
# PORTFOLIO_DB_PATH=C:\path\to\your\portfolio.sqlite

# Optional. If unset, backups use local/valorgrid/backups/.
# The Windows desktop app sets this automatically to its user data folder.
# VALORGRID_BACKUP_DIR=C:\path\to\your\backups
