{
  "compilerOptions": {
    "target": "ES2023",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@valorgrid/contracts": ["./packages/contracts/src"]
    }
  },
  "include": [
    "apps/server/src/**/*.js",
    "apps/server/server.js",
    "apps/web/src/app.js",
    "apps/web/src/**/*.js",
    "packages/contracts/src/**/*.ts",
    "test/**/*.js",
    "scripts/**/*.js"
  ]
}
